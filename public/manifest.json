{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "0.0.3",
  "author": "okarin",
  "description": "__MSG_ext_description__",
  "icons": {
    "16": "icon/icon-16.png",
    "32": "icon/icon-32.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },
  "content_scripts": [
    {
      "js": [
        "content_scripts.js"
      ],
      "matches": [
        "https://*.cybozu.com/g/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "default_locale": "ja",
  "permissions": [
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
